{
  "expo": {
    "name": "Panchayat",
    "slug": "panchayat-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1B4D35"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Panchayat uses your microphone so you can talk to PanchayatAI using voice."
      }
    },
    "android": {
      "package": "com.panchayat.app",
      "permissions": ["RECORD_AUDIO"]
    }
  }
}
